# ── Render Backend Environment Variables ──────────────────────────────────────
# Set these in: Render Dashboard → nbb-nbo-backend → Environment

# Neon PostgreSQL connection string
# Get from: Neon Dashboard → Connection Details → Connection string (with ?sslmode=require)
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# Persistent model directory (matches disk mountPath in render.yaml)
MODEL_DIR=/app/models

# Your Vercel frontend URL — allows CORS from the frontend
CORS_ORIGINS=https://nbb-nbo-platform.vercel.app

# Python version (set automatically via runtime.txt)
# PYTHON_VERSION=3.11.9
