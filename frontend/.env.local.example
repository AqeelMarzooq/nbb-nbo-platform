# Copy this to .env.local and fill in your values

# FastAPI backend URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-min-32-chars-change-in-production

# PostgreSQL (via Prisma — only needed for direct DB access from Next.js)
DATABASE_URL=postgresql://nbb_user:nbb_pass@localhost:5432/nbb_nbo
