# ── Vercel Frontend Environment Variables ─────────────────────────────────────
# Set these in: Vercel Dashboard → Project → Settings → Environment Variables

# Your Render backend URL (no trailing slash)
NEXT_PUBLIC_API_URL=https://nbb-nbo-backend.onrender.com

# NextAuth — must match your Vercel deployment URL exactly
NEXTAUTH_URL=https://nbb-nbo-platform.vercel.app
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Neon PostgreSQL — used by Prisma (Next.js server-side only, optional)
# Get both from: Neon Dashboard → Connection Details → Connection string
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
